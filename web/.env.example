# Base URL of the Laravel API. In dev, Vite proxies /api and /sanctum to
# http://localhost:8000 so cookies stay first-party for Sanctum auth.
VITE_API_BASE_URL=/api/v1
VITE_SANCTUM_URL=

# Google OAuth client id (Google Identity Services) for "Continue with Google".
# Must match the GOOGLE_CLIENT_ID configured on the Laravel API. Leave blank to
# render the Google button disabled.
VITE_GOOGLE_CLIENT_ID=
