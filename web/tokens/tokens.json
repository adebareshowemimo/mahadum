{
  "$meta": {
    "name": "Mahadum.360 Design Tokens",
    "version": "2.0.0",
    "description": "Brand-meaning oriented. Heritage Green (primary/correct/learning), African Gold (reward/coin/premium/streak — pairs with charcoal text), Deep Navy (premium/dark), Ivory (light base), Charcoal (text). Blue demoted to AI/learning-support. tokens.css is the runtime source of truth; tokens.ts mirrors it.",
    "modes": ["learner", "family", "school-admin"]
  },
  "color": {
    "heritage": { "50": "#ebf7f0", "100": "#cdebd9", "200": "#9fd8b6", "300": "#67bd8d", "400": "#379e69", "500": "#1a7d49", "600": "#14653b", "700": "#115231", "800": "#114228", "900": "#0e3622", "950": "#061d12" },
    "gold":     { "50": "#fdf8e7", "100": "#faedbf", "200": "#f6da83", "300": "#f1c544", "400": "#ecb01d", "500": "#d9970f", "600": "#b6740b", "700": "#91530d", "800": "#784213", "900": "#663715", "950": "#3b1d07" },
    "navy":     { "50": "#eef1f7", "100": "#d6dded", "200": "#b0bedb", "300": "#8195c1", "400": "#566ca3", "500": "#3c4f86", "600": "#2e3d6b", "700": "#253158", "800": "#1a2440", "900": "#111a33", "950": "#0a1124" },
    "ivory":    { "50": "#fdfbf6", "100": "#f8f2e6", "200": "#efe6d3", "300": "#e2d4ba", "400": "#cbb896" },
    "charcoal": { "50": "#f6f4f1", "100": "#e9e5df", "200": "#d6cfc5", "300": "#b3a99b", "400": "#8c8175", "500": "#6e655b", "600": "#564e46", "700": "#433d37", "800": "#2f2b27", "900": "#221f1b", "950": "#14120f" },
    "chore":    { "50": "#eef4ff", "100": "#d9e6ff", "200": "#bcd2fb", "300": "#8eb2f5", "400": "#5b8aec", "500": "#2f6fe0", "600": "#2156c2", "700": "#1c459b", "800": "#1b3c7e", "900": "#1b3568" },
    "ai":       { "50": "#eef0ff", "100": "#e0e2ff", "200": "#c6c8ff", "300": "#a3a4fc", "400": "#837ff7", "500": "#6359ee", "600": "#5340d4", "700": "#4632ab", "800": "#3a2c89", "900": "#322a6e" },
    "clay":     { "50": "#fdf3ef", "100": "#fbe2d8", "200": "#f6c4ae", "300": "#ee9c7c", "400": "#e57650", "500": "#d65a35", "600": "#bb4324", "700": "#9b3420" },
    "leaf":     { "50": "#edf9ef", "100": "#d1f0d8", "200": "#a6e0b3", "300": "#6fcb87", "400": "#43b063", "500": "#2f9b50", "600": "#237e40", "700": "#1d6535" },
    "red":      { "50": "#fdf2f2", "100": "#fbe1e1", "200": "#f6c4c5", "300": "#ee9a9c", "400": "#e56164", "500": "#dc3b40", "600": "#c12529", "700": "#a01e22" },
    "rainbow":  { "red": "#e5484d", "orange": "#e8833a", "yellow": "#e0a91b", "green": "#2f9b50", "teal": "#149e8e", "blue": "#2f6fe0", "purple": "#7c5cd6", "pink": "#d65a8f" }
  },
  "brand": {
    "heritage": "{color.heritage.500}",
    "gold": "{color.gold.500}",
    "navy": "{color.navy.900}",
    "ivory": "{color.ivory.50}",
    "charcoal": "{color.charcoal.900}",
    "choreBlue": "{color.chore.500}",
    "clay": "{color.clay.500}",
    "leaf": "{color.leaf.500}",
    "ai": "{color.ai.500}",
    "error": "{color.red.500}"
  },
  "semantic": {
    "light": {
      "background": "{color.ivory.50}", "surface": "#ffffff", "surface-muted": "{color.ivory.100}", "surface-sunken": "{color.ivory.200}",
      "foreground": "{color.charcoal.900}", "muted": "{color.charcoal.500}", "subtle": "{color.charcoal.400}", "border": "{color.ivory.300}",
      "primary": "{color.heritage.500}", "primary-fg": "#ffffff",
      "accent": "{color.gold.500}", "accent-fg": "{color.charcoal.900}",
      "success": "{color.leaf.500}", "warning": "{color.gold.500}", "warning-fg": "{color.charcoal.900}", "danger": "{color.red.500}", "info": "{color.chore.500}",
      "correct": "{color.heritage.500}", "wrong": "{color.red.500}", "coin": "{color.gold.500}", "grace": "{color.gold.500}", "chorePending": "{color.chore.500}", "speakingScore": "{color.ai.500}",
      "ring": "{color.heritage.400}"
    },
    "dark": {
      "background": "{color.navy.950}", "surface": "{color.navy.900}", "surface-muted": "{color.navy.800}",
      "foreground": "{color.ivory.100}", "muted": "{color.navy.300}", "border": "#26345c",
      "primary": "{color.heritage.400}", "primary-fg": "{color.navy.950}",
      "accent": "{color.gold.400}", "accent-fg": "{color.charcoal.950}",
      "success": "{color.leaf.500}", "warning": "{color.gold.400}", "danger": "{color.red.500}", "info": "{color.chore.400}",
      "ring": "{color.heritage.400}"
    }
  },
  "usage": {
    "heritage-green": "Primary CTA, success, correct answers, active learning state",
    "african-gold": "Rewards, coins, premium, streaks, celebrations — ALWAYS with charcoal text, never white",
    "deep-navy": "Premium background, dashboards, dark surfaces",
    "ivory-base": "Learner app background, family screens, reading comfort",
    "charcoal": "Text, headings, serious admin areas",
    "chore-blue": "Parent review, pending tasks, school workflow",
    "error-red": "Wrong answers, payment failure, danger",
    "clay-coral": "Cultural warmth, friendly highlights",
    "leaf-green": "Progress, completion, wallet success",
    "ai-indigo": "AI / learning support, speaking score — not a primary CTA"
  },
  "typography": {
    "fontFamily": { "display": "Fredoka, ui-rounded, system-ui, sans-serif", "sans": "Nunito, Inter, ui-sans-serif, system-ui, sans-serif", "mono": "JetBrains Mono, ui-monospace, monospace" },
    "fontSize": { "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.5rem", "3xl": "1.875rem", "4xl": "2.25rem", "5xl": "3rem" },
    "fontWeight": { "normal": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800 }
  },
  "radius": { "xs": "0.25rem", "sm": "0.375rem", "md": "0.625rem", "lg": "0.875rem", "xl": "1.25rem", "2xl": "1.75rem", "full": "9999px" },
  "shadow": {
    "sm": "0 1px 3px 0 rgb(34 31 27 / 0.08), 0 1px 2px -1px rgb(34 31 27 / 0.08)",
    "md": "0 4px 12px -2px rgb(34 31 27 / 0.10), 0 2px 6px -2px rgb(34 31 27 / 0.06)",
    "lg": "0 12px 28px -6px rgb(34 31 27 / 0.14), 0 6px 12px -6px rgb(34 31 27 / 0.08)",
    "gold": "0 8px 24px -6px rgb(217 151 15 / 0.40)",
    "heritage": "0 8px 24px -6px rgb(26 125 73 / 0.35)"
  },
  "breakpoint": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" }
}
