APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Web SPA (first-party) cookie auth. List the SPA hosts (host[:port], no scheme)
# that should receive stateful Sanctum cookies, and the SPA origins (with scheme)
# allowed through CORS. For cross-subdomain cookies set SESSION_DOMAIN=.example.com.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:8000
FRONTEND_URLS=http://localhost:3000,http://localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Payment gateways + telco SDP. Webhooks are signature-verified and fail closed
# when the corresponding secret is unset. Outbound checkout calls are OFF unless
# PAYMENT_GATEWAY_LIVE=true (local/CI use a no-op gateway → null checkout_url).
# Monnify is the default gateway. Sandbox public test credentials (from the docs)
# work out of the box: API key MK_TEST_SAF7HR5F3F / secret 4SEUD4WPYUYABGKN4XR9BQ2VG3XCMKED
# / contract 4934121686. Register MONNIFY_SECRET as the webhook hash in the dashboard.
MONNIFY_API_KEY=
MONNIFY_SECRET=
MONNIFY_CONTRACT_CODE=
# MONNIFY_BASE_URL=https://sandbox.monnify.com   # live: https://api.monnify.com
PAYSTACK_SECRET=
FLUTTERWAVE_SECRET=
FLUTTERWAVE_SECRET_HASH=
TELCO_WEBHOOK_SECRET=
PAYMENT_GATEWAY_LIVE=false
PAYMENT_DEFAULT_GATEWAY=monnify
# PAYSTACK_BASE_URL=https://api.paystack.co
# FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Telco SDP outbound (airtime charge + OTP SMS). OFF unless TELCO_SDP_LIVE=true.
TELCO_SDP_LIVE=false
TELCO_SDP_BASE_URL=
TELCO_SDP_TOKEN=

# Notification transports (SMS / WhatsApp / FCM push). OFF unless MESSAGING_LIVE=true.
# MESSAGING_TEXT_CHANNEL picks the text channel per notification: sms | whatsapp | none.
MESSAGING_LIVE=false
MESSAGING_TEXT_CHANNEL=sms
SMS_BASE_URL=
SMS_TOKEN=
SMS_SENDER=Mahadum360
WHATSAPP_BASE_URL=
WHATSAPP_TOKEN=
FCM_SERVER_KEY=
# FCM_URL=https://fcm.googleapis.com/fcm/send

# Google sign-in (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Referral economics
REFERRAL_RATE=0.20
REFERRAL_ESCROW_DAYS=14
REFERRAL_VELOCITY_LIMIT=15

# xAPI — IRI namespace for learning statements (stored locally; LRS push deferred).
XAPI_BASE_IRI=https://mahadum360.com/xapi
XAPI_ACTOR_HOMEPAGE=https://mahadum360.com
