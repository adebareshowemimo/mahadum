# Staging .env overlay. Copy .env.example to .env, then apply these overrides
# (values below marked CHANGE_ME must be filled in). Everything not listed
# here keeps its .env.example default.

APP_NAME="Mahadum360 (Staging)"
APP_ENV=staging
APP_KEY=                      # fill via: php artisan key:generate
APP_DEBUG=false
APP_URL=https://mahadum.agunfoninteractivity.com

LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mahadum_staging
DB_USERNAME=mahadum_staging
DB_PASSWORD=CHANGE_ME          # must match deploy/mysql-setup.sql

# Single-subdomain deploy: SPA and API share an origin, so no cross-domain
# SESSION_DOMAIN is needed — leave it unset (null) as in .env.example.
SANCTUM_STATEFUL_DOMAINS=mahadum.agunfoninteractivity.com
FRONTEND_URLS=https://mahadum.agunfoninteractivity.com

QUEUE_CONNECTION=database
CACHE_STORE=database

# Staging mail: route everything to a Mailtrap sandbox so nothing reaches real
# inboxes while testing (see the commented block in .env.example for prod/SendGrid).
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="staging@mahadum360.com"

# Leave payment/telco/messaging gateways at their .env.example defaults
# (PAYMENT_GATEWAY_LIVE=false, TELCO_SDP_LIVE=false, MESSAGING_LIVE=false)
# unless you're specifically testing a live integration on staging.
